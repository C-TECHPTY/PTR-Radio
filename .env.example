PORT=8091
NODE_ENV=development
DATABASE_PATH=./database/ptr-radio.db
AZURACAST_URL=https://radio.example.com
AZURACAST_STATION_ID=1
AZURACAST_STATION_SHORT_NAME=ptr-radio
AZURACAST_API_KEY=your_api_key_here
VITE_API_URL=/api
ON_AIR_TEST_OUTPUT_TYPE=file
ON_AIR_TEST_HOST=test-host.example.com
ON_AIR_TEST_PORT=8000
ON_AIR_TEST_MOUNT=/ptr-test
ON_AIR_TEST_USERNAME=test_source
ON_AIR_TEST_PASSWORD=replace_with_test_password
ON_AIR_TEST_CODEC=mp3
ON_AIR_TEST_BITRATE=128
ON_AIR_TEST_SAMPLE_RATE=44100
ON_AIR_TEST_CHANNELS=2
ON_AIR_TEST_FILE=
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
ON_AIR_MEDIA_CONNECT_TIMEOUT_MS=15000
ON_AIR_MEDIA_IDLE_TIMEOUT_MS=30000
ON_AIR_MEDIA_MAX_DOWNLOAD_MS=0
ON_AIR_MEDIA_CACHE_DIR=
ON_AIR_MEDIA_CACHE_MAX_MB=2048
ON_AIR_MEDIA_CACHE_TTL_HOURS=24
ON_AIR_LOCAL_STREAM_PORT=8092
